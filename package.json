{
  "name": "tabledown",
  "version": "0.4.0",
  "description": "Easily create markdown tables in your Javascript applications",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    },
    "./transform-stream": {
      "types": "./build/transformStream.d.ts",
      "import": "./build/transformStream.js"
    }
  },
  "files": [
    "build",
    "cli",
    "readme.md"
  ],
  "bin": {
    "tabledown": "cli/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "testCore": "tsx tests/core.ts",
    "testCli": "npm run build && tsx tests/cli.ts",
    "test": "npm run typecheck && npm run testCore && npm run testCli",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "table",
    "markdown"
  ],
  "author": "Adrian Sieber",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adius/tabledown.git"
  },
  "bugs": {
    "url": "https://github.com/adius/tabledown/issues"
  },
  "homepage": "https://github.com/adius/tabledown#readme"
}
